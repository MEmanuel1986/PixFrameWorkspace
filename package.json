{
  "name": "pixframe-workspace",
  "version": "1.1.0",
  "description": "PixFrame Workspace - Verwaltung für Fotografen und Videografen",
  "author": "MEmanuel1986",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n BE,FE,EL -c blue,green,magenta \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:backend": "cd backend && node server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 http://localhost:3001/api/health && electron .",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend && electron-builder",
    "start": "electron .",
    "postinstall": "cd backend && npm install && cd ../frontend && npm install"
  },
  "dependencies": {
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "de.victoria-elisabeth.pixframe-workspace",
    "productName": "PixFrame Workspace",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/dist/**/*",
      "!backend/node_modules/.cache",
      "!backend/data/**/*",
      "!backend/uploads/**/*",
      "!backend/backups/**/*",
      "!backend/logs/**/*",
      "!**/node_modules/**/*.md",
      "!**/node_modules/**/*.ts",
      "!**/node_modules/**/*.map"
    ],
    "extraResources": [],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PixFrame Workspace"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Office"
    }
  }
}
